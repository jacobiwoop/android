{
  "appId": "com.luminazen.app",
  "appName": "Byzo",
  "webDir": "dist",
  "plugins": {
    "Camera": {
      "permissions": ["camera", "photos"]
    },
    "Geolocation": {
      "permissions": ["location"]
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#ffffff",
    "webContentsDebuggingEnabled": true
  },
  "ios": {
    "contentInset": "automatic"
  }
}
